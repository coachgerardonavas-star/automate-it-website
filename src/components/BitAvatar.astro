---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
  size?: number;
  showTooltip?: boolean;
}

const { lang = "es", size = 32, showTooltip = false } = Astro.props;
const t = translations[lang].bit;

const sizePx = `${size}px`;
const fontSize =
  size <= 24 ? "9px" : size <= 32 ? "11px" : size <= 40 ? "13px" : "15px";
---

<span
  class:list={["bit-avatar", { "bit-avatar--has-tooltip": showTooltip }]}
  style={`width:${sizePx};height:${sizePx};font-size:${fontSize};`}
  data-tooltip={t.tooltip}
  role="img"
  aria-label={t.avatarAlt}
>
  <span class="bit-avatar-fallback">BIT</span>
</span>

<style>
  .bit-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-navy);
    border: 1px solid rgba(0, 217, 255, 0.4);
    box-shadow: var(--glow-cyan-sm);
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .bit-avatar-fallback {
    font-family: "Manifold CF", Montserrat, system-ui, sans-serif;
    font-weight: 800;
    color: var(--color-cyan);
    letter-spacing: 0.5px;
    line-height: 1;
  }

  .bit-avatar--has-tooltip {
    cursor: help;
  }

  .bit-avatar--has-tooltip::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 10px;
    background: var(--neutral-700);
    color: var(--color-white);
    font-family: "Open Sans", system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    border-radius: var(--r-xs);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms var(--ease-brand);
    z-index: 60;
  }

  .bit-avatar--has-tooltip:hover::after,
  .bit-avatar--has-tooltip:focus-visible::after {
    opacity: 1;
  }
</style>
