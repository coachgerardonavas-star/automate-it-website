---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
  size?: number;
  showTooltip?: boolean;
}

const { lang = "es", size = 32, showTooltip = false } = Astro.props;
const t = translations[lang].bit;
const sizePx = `${size}px`;
---

<span
  class:list={["bit-avatar", { "bit-avatar--has-tooltip": showTooltip }]}
  style={`width:${sizePx};height:${sizePx};`}
  data-tooltip={t.tooltip}
  role="img"
  aria-label={t.avatarAlt}
>
  <img
    class="bit-avatar-img"
    src="/assets/mascota.webp"
    alt=""
    aria-hidden="true"
  />
</span>

<style>
  .bit-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    background: transparent;
  }

  .bit-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
    /* clip-path circular instead of overflow:hidden on parent —
       keeps the tooltip ::after free to overflow below */
    clip-path: circle(50% at 50% 50%);
    display: block;
  }

  .bit-avatar--has-tooltip {
    cursor: help;
  }

  .bit-avatar--has-tooltip::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 10px;
    background: var(--neutral-700);
    color: var(--color-white);
    font-family: "Open Sans", system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    border-radius: var(--r-xs);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms var(--ease-brand);
    z-index: 60;
  }

  .bit-avatar--has-tooltip:hover::after,
  .bit-avatar--has-tooltip:focus-visible::after {
    opacity: 1;
  }
</style>

