---
import type { CollectionEntry } from "astro:content";
import { translations, type Lang } from "../i18n/translations";
import { jsonLd } from "../lib/jsonld";

interface Props {
  lang?: Lang;
  post: CollectionEntry<"blog">;
}

const { lang = "es", post } = Astro.props;
const t = translations[lang].blog;
const blogBase = lang === "en" ? "/en/blog" : "/blog";
const dateLocale = lang === "en" ? "en-US" : "es-ES";
const dateFmt = new Intl.DateTimeFormat(dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(post.data.pubDate);

const canonicalUrl = `https://yourbizupgraded.com${blogBase}/${post.slug}/`;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  inLanguage: post.data.lang === "en" ? "en-US" : "es-MX",
  author: {
    "@type": "Person",
    name: post.data.author,
  },
  publisher: {
    "@type": "Organization",
    name: "Automate IT",
    logo: {
      "@type": "ImageObject",
      url: "https://yourbizupgraded.com/assets/logo-hero.png",
    },
  },
  keywords: post.data.tags.join(", "),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
};

const { Content } = await post.render();
---

<script
  type="application/ld+json"
  is:inline
  set:html={jsonLd(blogPostingSchema)}
/>

<article class="py-16 sm:py-24">
  <div class="max-w-3xl mx-auto px-5 lg:px-8">
    <a
      href={blogBase}
      class="inline-flex items-center gap-2 text-xs sm:text-sm text-[var(--color-text-muted)] hover:text-[var(--color-navy)] transition-colors duration-200 ease-brand mb-10"
    >
      {t.backToBlog}
    </a>

    <header class="mb-10">
      <p class="text-[11px] sm:text-xs tracking-[0.28em] uppercase text-[var(--color-blue)] mb-4 font-semibold">
        {t.eyebrow}
      </p>
      <h1 class="font-heading text-3xl sm:text-5xl leading-tight mb-5">
        {post.data.title}
      </h1>
      <p class="text-base text-[var(--color-text-secondary)] leading-relaxed mb-6">
        {post.data.description}
      </p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-[var(--color-text-muted)]">
        <span>
          {t.byAuthor} <strong class="text-[var(--color-text-primary)]">{post.data.author}</strong>
        </span>
        <span aria-hidden="true">·</span>
        <span>{t.publishedOn} {dateFmt}</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="px-2 py-1 rounded-xs text-[10px] tracking-widest uppercase bg-[var(--color-bg-soft)] border border-[var(--color-border)] text-[var(--color-text-muted)]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose-blog">
      <Content />
    </div>
  </div>
</article>

<style>
  .prose-blog {
    color: var(--color-text-secondary);
    font-size: 16px;
    line-height: 1.75;
  }
  .prose-blog :global(p) {
    margin: 0 0 1.25rem;
  }
  .prose-blog :global(h2) {
    font-family: "Manifold CF", Montserrat, system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.6rem;
    line-height: 1.2;
    margin: 2.5rem 0 1rem;
    color: var(--color-text-primary);
  }
  .prose-blog :global(h3) {
    font-family: "Manifold CF", Montserrat, system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    line-height: 1.25;
    margin: 2rem 0 0.75rem;
    color: var(--color-text-primary);
  }
  .prose-blog :global(ul),
  .prose-blog :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-blog :global(li) {
    margin: 0.5rem 0;
  }
  .prose-blog :global(strong) {
    color: var(--color-text-primary);
    font-weight: 700;
  }
  .prose-blog :global(a) {
    color: var(--color-blue);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose-blog :global(a:hover) {
    color: var(--color-navy);
  }
  .prose-blog :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .prose-blog :global(blockquote) {
    border-left: 3px solid var(--color-cyan);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .prose-blog :global(code) {
    background: rgba(0, 153, 187, 0.08);
    color: var(--color-blue);
    padding: 1px 6px;
    border-radius: var(--r-xs);
    font-family: "Courier New", monospace;
    font-size: 0.9em;
  }
</style>
