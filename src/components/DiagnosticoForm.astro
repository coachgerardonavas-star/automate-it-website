---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].diagnosticoPage;
const ctaCommon = translations[lang].ctaFinal;
const homeHref = lang === "en" ? "/en/" : "/";
---

<section class="py-16 sm:py-24">
  <div class="max-w-3xl mx-auto px-5 lg:px-8">
    <a
      href={homeHref}
      class="inline-flex items-center gap-2 text-xs sm:text-sm text-white/55 hover:text-brand-cyan transition-colors mb-10"
    >
      {t.backLink}
    </a>

    <header class="mb-10">
      <p class="text-[11px] sm:text-xs tracking-[0.28em] uppercase text-brand-cyan mb-4 font-semibold">
        {ctaCommon.eyebrow}
      </p>
      <h1 class="font-heading text-3xl sm:text-5xl leading-tight mb-4">
        {t.heading}
      </h1>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed">
        {t.subheading}
      </p>
    </header>

    <form
      id="diag-form"
      class="space-y-5"
      novalidate
      data-error-msg={ctaCommon.errorAllFields}
      data-error-fallback={t.errorSubmitFallback}
      data-submitting={t.submitting}
      data-submit-label={t.submit}
    >
      <label class="block">
        <span class="block text-xs tracking-wider uppercase text-white/55 mb-2">
          {t.labels.name}
        </span>
        <input
          type="text"
          name="name"
          required
          autocomplete="name"
          class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 text-white focus:outline-none focus:border-brand-cyan transition-colors"
        />
      </label>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <label class="block">
          <span class="block text-xs tracking-wider uppercase text-white/55 mb-2">
            {t.labels.email}
          </span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 text-white focus:outline-none focus:border-brand-cyan transition-colors"
          />
        </label>
        <label class="block">
          <span class="block text-xs tracking-wider uppercase text-white/55 mb-2">
            {t.labels.phone}
          </span>
          <input
            type="tel"
            name="phone"
            required
            autocomplete="tel"
            class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 text-white focus:outline-none focus:border-brand-cyan transition-colors"
          />
        </label>
      </div>

      <label class="block">
        <span class="block text-xs tracking-wider uppercase text-white/55 mb-2">
          {t.labels.bizType}
        </span>
        <select
          name="business_type"
          required
          class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 text-white focus:outline-none focus:border-brand-cyan transition-colors appearance-none cursor-pointer"
        >
          <option value="" class="bg-brand-bg">
            {t.labels.bizTypePlaceholder}
          </option>
          {
            ctaCommon.businessTypes.map((bt) => (
              <option value={bt} class="bg-brand-bg">
                {bt}
              </option>
            ))
          }
        </select>
      </label>

      <div data-hipaa-field class="hidden">
        <label class="flex items-start gap-3 cursor-pointer p-4 rounded border border-brand-cyan/30 bg-brand-cyan/[0.04] hover:border-brand-cyan/50 transition-colors duration-200 ease-brand">
          <input
            type="checkbox"
            name="hipaa_compliant"
            value="true"
            class="mt-1 accent-brand-cyan shrink-0"
          />
          <span class="min-w-0">
            <span class="block text-sm text-white/95 font-semibold leading-snug">
              {t.hipaaQuestion}
            </span>
            <span class="block text-xs text-white/60 mt-1.5 leading-relaxed">
              {t.hipaaHint}
            </span>
          </span>
        </label>
      </div>

      <label class="block">
        <span class="block text-xs tracking-wider uppercase text-white/55 mb-2">
          {t.labels.problem}
        </span>
        <textarea
          name="problem"
          required
          rows="4"
          placeholder={t.labels.problemPlaceholder}
          class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 text-white placeholder-white/30 focus:outline-none focus:border-brand-cyan transition-colors resize-y"
        ></textarea>
      </label>

      <fieldset>
        <legend class="block text-xs tracking-wider uppercase text-white/55 mb-3">
          {t.labels.urgency}
        </legend>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {
            t.labels.urgencyOptions.map((opt, i) => (
              <label class="flex items-center gap-3 px-4 py-3 rounded border border-white/10 bg-white/[0.025] hover:border-brand-cyan/40 cursor-pointer transition-colors">
                <input
                  type="radio"
                  name="urgency"
                  value={opt.value}
                  required={i === 0}
                  class="accent-brand-cyan"
                />
                <span class="text-sm text-white/85">{opt.label}</span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <p id="diag-error" class="hidden text-sm text-red-400"></p>

      <button
        type="submit"
        class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 rounded font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
      >
        {t.submit}
      </button>
    </form>

    <div
      id="diag-success"
      class="hidden mt-8 p-6 rounded-lg border border-brand-lime/40 bg-brand-lime/5"
      role="status"
      aria-live="polite"
    >
      <p class="font-heading text-xl mb-2 text-brand-lime">
        {t.successHeading}
      </p>
      <p class="text-sm sm:text-base text-white/85">{t.successBody}</p>
    </div>

    <p class="mt-8 text-xs text-white/45">{t.privacyDisclaimer}</p>
  </div>
</section>

<script>
  import { submitToHubSpot } from "../lib/hubspot";
  import { HUBSPOT_FORM_GUID_DIAGNOSTICO } from "../config/site";

  const form = document.getElementById("diag-form") as HTMLFormElement | null;
  const error = document.getElementById("diag-error");
  const success = document.getElementById("diag-success");

  const HIPAA_BIZ_TYPES = ["Salud / Terapia", "Health / Therapy"];

  if (form) {
    const bizSelect = form.querySelector(
      'select[name="business_type"]'
    ) as HTMLSelectElement | null;
    const hipaaField = form.querySelector(
      "[data-hipaa-field]"
    ) as HTMLElement | null;
    const hipaaCheckbox = form.querySelector(
      'input[name="hipaa_compliant"]'
    ) as HTMLInputElement | null;

    const toggleHipaa = () => {
      if (!bizSelect || !hipaaField) return;
      const isHealthcare = HIPAA_BIZ_TYPES.includes(bizSelect.value);
      hipaaField.classList.toggle("hidden", !isHealthcare);
      if (!isHealthcare && hipaaCheckbox) hipaaCheckbox.checked = false;
    };

    bizSelect?.addEventListener("change", toggleHipaa);
    toggleHipaa();
  }

  function getUrgencyLabel(form: HTMLFormElement): string {
    const checked = form.querySelector<HTMLInputElement>(
      'input[name="urgency"]:checked'
    );
    if (!checked) return "";
    const labelEl = checked.closest("label");
    const labelSpan = labelEl?.querySelector("span");
    return labelSpan?.textContent?.trim() ?? checked.value;
  }

  function splitName(full: string): { firstname: string; lastname: string } {
    const parts = full.trim().split(/\s+/);
    if (parts.length === 1) return { firstname: parts[0], lastname: "" };
    return {
      firstname: parts[0],
      lastname: parts.slice(1).join(" "),
    };
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !error || !success) return;

    error.classList.add("hidden");
    error.textContent = "";

    if (!form.checkValidity()) {
      error.textContent = form.dataset.errorMsg ?? "";
      error.classList.remove("hidden");
      form.reportValidity();
      return;
    }

    const submitBtn = form.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement | null;
    const restoreBtn = () => {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = form.dataset.submitLabel ?? "";
      }
    };
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = form.dataset.submitting ?? "";
    }

    const data = Object.fromEntries(new FormData(form)) as Record<
      string,
      string
    >;
    const { firstname, lastname } = splitName(data.name ?? "");
    const urgencyLabel = getUrgencyLabel(form);
    const message =
      `Problema: ${data.problem ?? ""}\n\n` +
      `Urgencia: ${urgencyLabel || data.urgency || ""}`;

    const hipaaWrapper = form.querySelector(
      "[data-hipaa-field]"
    ) as HTMLElement | null;
    const hipaaCheckboxEl = form.querySelector(
      'input[name="hipaa_compliant"]'
    ) as HTMLInputElement | null;
    const hipaaVisible =
      !!hipaaWrapper && !hipaaWrapper.classList.contains("hidden");

    const fields = [
      { name: "firstname", value: firstname },
      { name: "lastname", value: lastname },
      { name: "email", value: data.email ?? "" },
      { name: "phone", value: data.phone ?? "" },
      { name: "industry", value: data.business_type ?? "" },
      { name: "message", value: message },
    ];
    if (hipaaVisible) {
      fields.push({
        name: "hipaa_compliant",
        value: hipaaCheckboxEl?.checked ? "true" : "false",
      });
    }

    try {
      await submitToHubSpot(HUBSPOT_FORM_GUID_DIAGNOSTICO, fields);
      form.classList.add("hidden");
      success.classList.remove("hidden");
    } catch (err) {
      console.error("[lead] /diagnostico HubSpot error:", err);
      error.textContent = form.dataset.errorFallback ?? "";
      error.classList.remove("hidden");
      restoreBtn();
    }
  });
</script>
