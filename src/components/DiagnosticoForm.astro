---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].diagnosticoPage;
const businessTypes = translations[lang].ctaFinal.businessTypes;
---

<form
  id="diag-form"
  class="space-y-6"
  novalidate
  data-submitting={t.submitting}
  data-submit-label={t.submit}
  data-error-fallback={t.errorSubmitFallback}
  data-lang={lang}
>
  <label class="block">
    <span class="block text-sm font-semibold text-white/85 mb-2">{t.labels.name}</span>
    <input
      type="text"
      name="name"
      required
      autocomplete="name"
      class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 placeholder-white/40 text-white focus:outline-none focus:border-brand-cyan transition-colors"
    />
  </label>

  <label class="block">
    <span class="block text-sm font-semibold text-white/85 mb-2">{t.labels.email}</span>
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 placeholder-white/40 text-white focus:outline-none focus:border-brand-cyan transition-colors"
    />
  </label>

  <label class="block">
    <span class="block text-sm font-semibold text-white/85 mb-2">{t.labels.phone}</span>
    <input
      type="tel"
      name="phone"
      autocomplete="tel"
      class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 placeholder-white/40 text-white focus:outline-none focus:border-brand-cyan transition-colors"
    />
  </label>

  <label class="block">
    <span class="block text-sm font-semibold text-white/85 mb-2">{t.labels.addressLabel}</span>
    <input
      type="text"
      name="address"
      autocomplete="address-level2"
      placeholder={t.labels.addressPlaceholder}
      class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 placeholder-white/40 text-white focus:outline-none focus:border-brand-cyan transition-colors"
    />
  </label>

  <label class="block">
    <span class="block text-sm font-semibold text-white/85 mb-2">{t.labels.bizType}</span>
    <select
      name="business_type"
      required
      class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 text-white focus:outline-none focus:border-brand-cyan transition-colors appearance-none cursor-pointer"
    >
      <option value="" class="bg-brand-bg">{t.labels.bizTypePlaceholder}</option>
      {
        businessTypes.map((bt) => (
          <option value={bt} class="bg-brand-bg">
            {bt}
          </option>
        ))
      }
    </select>
  </label>

  <label class="block">
    <span class="block text-sm font-semibold text-white/85 mb-2">{t.labels.problem}</span>
    <textarea
      name="problem"
      rows="4"
      required
      placeholder={t.labels.problemPlaceholder}
      class="w-full px-4 py-3 rounded bg-white/[0.04] border border-white/10 placeholder-white/40 text-white focus:outline-none focus:border-brand-cyan transition-colors resize-y"
    ></textarea>
  </label>

  <fieldset>
    <legend class="block text-sm font-semibold text-white/85 mb-3">{t.labels.urgency}</legend>
    <div class="space-y-2">
      {
        t.labels.urgencyOptions.map((opt) => (
          <label class="flex items-center gap-3 cursor-pointer">
            <input
              type="radio"
              name="urgency"
              value={opt.value}
              required
              class="w-4 h-4 accent-brand-cyan cursor-pointer"
            />
            <span class="text-sm text-white/85">{opt.label}</span>
          </label>
        ))
      }
    </div>
  </fieldset>

  <div class="pt-2">
    <label class="flex items-start gap-3 cursor-pointer">
      <input
        type="checkbox"
        name="hipaa"
        value="yes"
        class="mt-0.5 w-4 h-4 accent-brand-cyan cursor-pointer"
      />
      <span class="flex-1">
        <span class="block text-sm font-semibold text-white/85">{t.hipaaQuestion}</span>
        <span class="block text-xs text-white/55 mt-1">{t.hipaaHint}</span>
      </span>
    </label>
  </div>

  <div class="pt-4">
    <button
      type="submit"
      class="btn-cta w-full inline-flex items-center justify-center px-6 py-3 rounded-sm font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
    >
      {t.submit}
    </button>
  </div>

  <p class="text-xs text-white/55 pt-2">{t.privacyDisclaimer}</p>
</form>

<p id="diag-error" class="hidden text-sm text-red-400 mt-4" role="alert"></p>

<div
  id="diag-success"
  class="hidden p-8 rounded-lg border border-brand-lime/40 bg-brand-lime/5"
  role="status"
  aria-live="polite"
>
  <p class="font-heading text-2xl mb-3 text-brand-lime">{t.successHeading}</p>
  <p class="text-base text-white/85 leading-relaxed">{t.successBody}</p>
</div>

<script>
  import { submitToHubSpot } from "../lib/hubspot";
  import { HUBSPOT_FORM_GUID_DIAGNOSTICO } from "../config/site";

  const form = document.getElementById("diag-form") as HTMLFormElement | null;
  const error = document.getElementById("diag-error");
  const success = document.getElementById("diag-success");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !error || !success) return;

    error.classList.add("hidden");
    error.textContent = "";

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const submitBtn = form.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement | null;
    const restoreBtn = () => {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = form.dataset.submitLabel ?? "";
      }
    };
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = form.dataset.submitting ?? "";
    }

    const data = Object.fromEntries(new FormData(form)) as Record<string, string>;
    const lang = form.dataset.lang ?? "es";

    const metaPieces = [
      data.urgency ? `urgency: ${data.urgency}` : "",
      `hipaa: ${data.hipaa === "yes" ? "yes" : "no"}`,
      `lang: ${lang}`,
    ].filter(Boolean);
    const message = `${data.problem ?? ""}\n\n[${metaPieces.join(" | ")}]`;

    try {
      await submitToHubSpot(HUBSPOT_FORM_GUID_DIAGNOSTICO, [
        { name: "firstname", value: data.name ?? "" },
        { name: "email", value: data.email ?? "" },
        { name: "phone", value: data.phone ?? "" },
        { name: "address", value: data.address ?? "" },
        { name: "industry", value: data.business_type ?? "" },
        { name: "message", value: message },
      ]);
      form.classList.add("hidden");
      success.classList.remove("hidden");
    } catch (err) {
      console.error("[lead] diagnostic HubSpot error:", err);
      error.textContent = form.dataset.errorFallback ?? "";
      error.classList.remove("hidden");
      restoreBtn();
    }
  });
</script>
