---
import { translations, type Lang } from "../i18n/translations";
import { switchLangPath } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].footer;
const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const esHref = lang === "es" ? null : switchLangPath(currentPath, "es");
const enHref = lang === "en" ? null : switchLangPath(currentPath, "en");
const copyright = t.copyright.replace("{year}", String(year));
---

<footer class="border-t border-white/10 bg-[var(--color-bg-dark)] pt-16 pb-10">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8 mb-12">
      <div class="md:col-span-5">
        <a
          href={lang === "en" ? "/en/" : "/"}
          class="inline-flex items-center mb-4"
          aria-label={lang === "en" ? "Automate IT — home" : "Automate IT — inicio"}
        >
          <span class="font-heading text-xl tracking-tight">
            AUTOMATE <span class="text-brand-cyan">IT</span>
          </span>
        </a>
        <p class="font-heading text-base text-white/60 mb-4">
          {t.tagline}
        </p>
        <p class="text-sm text-white/55 leading-relaxed max-w-sm">
          {t.description}
        </p>
      </div>

      <nav class="md:col-span-3" aria-label={t.productHeading}>
        <h3 class="text-[11px] tracking-[0.22em] uppercase text-white/45 font-semibold mb-4">
          {t.productHeading}
        </h3>
        <ul class="space-y-2.5">
          {
            t.productLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/75 hover:text-brand-cyan transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav class="md:col-span-2" aria-label={t.empresaHeading}>
        <h3 class="text-[11px] tracking-[0.22em] uppercase text-white/45 font-semibold mb-4">
          {t.empresaHeading}
        </h3>
        <ul class="space-y-2.5">
          {
            t.empresaLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/75 hover:text-brand-cyan transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="md:col-span-2">
        <h3 class="text-[11px] tracking-[0.22em] uppercase text-white/45 font-semibold mb-4">
          {t.contactHeading}
        </h3>
        <a
          href="mailto:automateit@yourbizupgraded.com"
          class="text-sm text-white/75 hover:text-brand-cyan transition-colors break-all"
        >
          automateit@<br class="hidden md:inline" />yourbizupgraded.com
        </a>
      </div>
    </div>

    <div class="pt-8 border-t border-white/10 flex flex-col sm:flex-row gap-4 sm:gap-6 sm:items-center sm:justify-between">
      <p class="text-xs text-white/45">
        {copyright}
      </p>

      <div
        class="inline-flex items-center gap-1 text-xs"
        role="group"
        aria-label={t.switcherLabel}
      >
        {
          esHref ? (
            <a
              href={esHref}
              class="px-3 py-1.5 rounded border border-white/15 text-white/75 hover:text-brand-cyan hover:border-brand-cyan/40 transition-colors"
            >
              {t.langEs}
            </a>
          ) : (
            <span
              aria-current="true"
              class="px-3 py-1.5 rounded border border-brand-cyan/40 text-brand-cyan font-semibold"
            >
              {t.langEs}
            </span>
          )
        }
        {
          enHref ? (
            <a
              href={enHref}
              class="px-3 py-1.5 rounded border border-white/15 text-white/75 hover:text-brand-cyan hover:border-brand-cyan/40 transition-colors"
            >
              {t.langEn}
            </a>
          ) : (
            <span
              aria-current="true"
              class="px-3 py-1.5 rounded border border-brand-cyan/40 text-brand-cyan font-semibold"
            >
              {t.langEn}
            </span>
          )
        }
      </div>
    </div>
  </div>
</footer>
