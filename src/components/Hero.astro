---
import { type Lang } from "../i18n/translations";
import { getCopy } from "../i18n/site-copy";
import BitAvatar from "./BitAvatar.astro";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const copy = getCopy(lang);
const t = copy.hero;
const bit = copy.bit;
const diagPath = lang === "en" ? "/en/diagnostic" : "/diagnostico";
---

<section class="relative min-h-[88vh] flex items-center overflow-hidden">
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-navy/25 via-brand-bg to-brand-bg"></div>
    <div class="absolute -top-40 -right-32 h-[40rem] w-[40rem] rounded-full bg-brand-cyan/10 blur-3xl"></div>
    <div class="absolute bottom-0 -left-40 h-[30rem] w-[30rem] rounded-full bg-brand-blue/15 blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-20 sm:py-28 w-full">
    <p class="font-sans text-[11px] sm:text-xs tracking-[0.28em] uppercase text-brand-cyan mb-6 font-semibold">
      {t.eyebrow}
    </p>

    <h1 class="font-heading text-4xl sm:text-6xl lg:text-7xl leading-[1.04] max-w-4xl">
      {t.h1Line1}<br />
      <span class="text-brand-cyan">{t.h1Line2}</span>
    </h1>

    <p class="mt-6 max-w-2xl text-base sm:text-lg text-white/75 leading-relaxed">
      {t.subtitle}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4">
      <a
        href={diagPath}
        class="inline-flex items-center justify-center px-6 py-3 rounded-sm font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 transition-colors duration-200 ease-brand"
      >
        {t.ctaPrimary}
      </a>
      <a
        href="#como-funciona"
        class="inline-flex items-center justify-center px-6 py-3 rounded-sm font-semibold border border-white/20 hover:border-brand-cyan/60 hover:text-brand-cyan transition-colors duration-200 ease-brand"
      >
        {t.ctaSecondary}
      </a>
    </div>

    <a
      href="#agentes"
      class="mt-8 inline-flex items-center gap-3 group text-white/70 hover:text-brand-cyan transition-colors duration-200 ease-brand"
      aria-label={bit.anchorLabel}
    >
      <BitAvatar lang={lang} size={36} loading="eager" />
      <span class="text-sm sm:text-base font-semibold">
        {bit.heroLine}
      </span>
    </a>

    <p class="mt-12 text-xs sm:text-sm text-white/45 max-w-md">
      {t.microcopy}
    </p>
  </div>
</section>
