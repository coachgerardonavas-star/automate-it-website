---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
  doc: "privacy" | "terms";
  lastUpdated: string;
}

const { lang = "es", doc, lastUpdated } = Astro.props;
const t = translations[lang].legal;
const docT = doc === "privacy" ? t.privacy : t.terms;
const homeHref = lang === "en" ? "/en/" : "/";
const backLabel = lang === "en" ? "← Back to home" : "← Volver al inicio";
---

<section class="bg-[#050A18] text-white min-h-screen py-16 sm:py-24">
  <div class="max-w-3xl mx-auto px-5 lg:px-8">
    <a
      href={homeHref}
      class="inline-flex items-center gap-2 text-xs sm:text-sm text-white/55 hover:text-brand-cyan transition-colors mb-10"
    >
      {backLabel}
    </a>

    <header class="mb-12">
      <h1 class="font-heading text-3xl sm:text-5xl leading-tight mb-3 text-white">
        {docT.title}
      </h1>
      <p class="text-xs sm:text-sm text-white/50">
        {t.lastUpdated} {lastUpdated}
      </p>
    </header>

    <div class="space-y-10">
      {
        docT.sections.map((section) => (
          <section>
            <h2 class="font-heading text-xl sm:text-2xl mb-3 text-white">
              {section.heading}
            </h2>
            <p class="text-sm sm:text-base text-white/80 leading-relaxed">
              {section.body}
            </p>
          </section>
        ))
      }
    </div>
  </div>
</section>
