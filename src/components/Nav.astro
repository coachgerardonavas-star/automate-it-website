---
const links = [
  { label: "Cómo funciona", href: "#como-funciona" },
  { label: "Agentes", href: "#agentes" },
  { label: "Paquetes", href: "#paquetes" },
  { label: "Para quién", href: "#para-quien" },
];
---

<nav class="sticky top-0 z-50 backdrop-blur-md bg-brand-bg/80 border-b border-white/5">
  <div class="max-w-7xl mx-auto px-5 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Automate IT — inicio">
      <span class="font-heading text-base sm:text-lg tracking-tight">
        AUTOMATE <span class="text-brand-cyan">IT</span>
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-white/75 hover:text-white transition-colors"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="#diagnostico"
      class="inline-flex items-center px-4 py-2 rounded text-xs sm:text-sm font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 transition-colors"
    >
      Diagnóstico gratuito
    </a>
  </div>
</nav>
