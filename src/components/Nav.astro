---
import { type Lang } from "../i18n/translations";
import { getCopy } from "../i18n/site-copy";
import BitAvatar from "./BitAvatar.astro";
import { switchLangPath } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const copy = getCopy(lang);
const t = copy.nav;
const footerT = copy.footer;
const ctaHref = "/diagnostico";
const homeHref = lang === "en" ? "/en/" : "/";
const currentPath = Astro.url.pathname;
const otherLang: Lang = lang === "en" ? "es" : "en";
const otherLangHref = switchLangPath(currentPath, otherLang);
const esHref = switchLangPath(currentPath, "es");
const enHref = switchLangPath(currentPath, "en");
---

<nav class="sticky top-0 z-50 backdrop-blur-md bg-brand-bg/85 border-b border-white/5">
  <input
    id="nav-mobile-toggle"
    type="checkbox"
    class="peer sr-only"
    aria-label={t.cta}
  />

  <div class="max-w-7xl mx-auto px-5 lg:px-8 h-16 flex items-center justify-between gap-3">
    <a
      href={homeHref}
      class="flex items-center gap-3 shrink-0"
      aria-label={t.logoLabel}
    >
      <BitAvatar lang={lang} size={28} showTooltip={true} />
      <span class="font-heading text-base sm:text-lg tracking-tight">
        AUTOMATE <span class="text-brand-cyan">IT</span>
      </span>
      <span
        class="hidden sm:inline-flex items-center text-[10px] tracking-[0.22em] uppercase text-white/55 font-semibold pl-3 ml-1 border-l border-white/15"
        aria-label="Florida"
      >
        Florida
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-7 text-sm">
      {
        t.links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-white/75 hover:text-white transition-colors duration-200 ease-brand"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2 md:gap-4">
      <div
        class="lang-toggle"
        data-active={lang}
        role="group"
        aria-label={footerT.switcherLabel}
      >
        <span class="lang-toggle-pill" aria-hidden="true"></span>
        {
          lang === "es" ? (
            <span
              class="lang-toggle-option is-active"
              aria-current="true"
            >
              <img
                src="https://flagcdn.com/ve.svg"
                width="16"
                height="12"
                alt="VE"
                class="lang-toggle-flag"
              />
              <span>ES</span>
            </span>
          ) : (
            <a href={esHref} class="lang-toggle-option">
              <img
                src="https://flagcdn.com/ve.svg"
                width="16"
                height="12"
                alt="VE"
                class="lang-toggle-flag"
              />
              <span>ES</span>
            </a>
          )
        }
        {
          lang === "en" ? (
            <span
              class="lang-toggle-option is-active"
              aria-current="true"
            >
              <img
                src="https://flagcdn.com/us.svg"
                width="16"
                height="12"
                alt="US"
                class="lang-toggle-flag"
              />
              <span>EN</span>
            </span>
          ) : (
            <a href={enHref} class="lang-toggle-option">
              <img
                src="https://flagcdn.com/us.svg"
                width="16"
                height="12"
                alt="US"
                class="lang-toggle-flag"
              />
              <span>EN</span>
            </a>
          )
        }
        {
          lang === "es" && (
            <span class="lang-toggle-tooltip" role="tooltip">
              Switch to English →
            </span>
          )
        }
      </div>

      <a
        href={ctaHref}
        class="hidden md:inline-flex items-center px-4 py-2 rounded-sm text-xs sm:text-sm font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 transition-colors duration-200 ease-brand"
      >
        {t.cta}
      </a>

      <label
        for="nav-mobile-toggle"
        class="md:hidden cursor-pointer p-2 -mr-2 nav-hamburger-label"
        aria-controls="nav-mobile-panel"
      >
        <span class="hamburger-icon">
          <span class="line line-1"></span>
          <span class="line line-2"></span>
          <span class="line line-3"></span>
        </span>
      </label>
    </div>
  </div>

  <div
    id="nav-mobile-panel"
    class="nav-mobile-panel md:hidden border-t border-white/5 bg-brand-bg"
  >
    <ul class="px-5 py-3">
      {
        t.links.map((l) => (
          <li>
            <a
              href={l.href}
              class="block py-3 text-base text-white/85 hover:text-brand-cyan border-b border-white/5 last:border-b-0 transition-colors"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="px-5 pb-5 pt-4 border-t border-white/5">
      <a
        href={ctaHref}
        class="block w-full text-center px-5 py-3 rounded-sm text-sm font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 transition-colors"
      >
        {t.cta}
      </a>
    </div>
  </div>
</nav>

<style>
  .nav-mobile-panel {
    display: none;
  }
  #nav-mobile-toggle:checked ~ .nav-mobile-panel {
    display: block;
    animation: navPanelIn 220ms cubic-bezier(0.2, 0, 0, 1);
  }

  .hamburger-icon {
    display: block;
    position: relative;
    width: 22px;
    height: 16px;
  }
  .hamburger-icon .line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: #ffffff;
    border-radius: 2px;
    transition:
      transform 220ms cubic-bezier(0.2, 0, 0, 1),
      opacity 160ms cubic-bezier(0.2, 0, 0, 1),
      top 220ms cubic-bezier(0.2, 0, 0, 1);
  }
  .hamburger-icon .line-1 {
    top: 0;
  }
  .hamburger-icon .line-2 {
    top: 7px;
  }
  .hamburger-icon .line-3 {
    top: 14px;
  }

  #nav-mobile-toggle:checked ~ div .hamburger-icon .line-1 {
    top: 7px;
    transform: rotate(45deg);
  }
  #nav-mobile-toggle:checked ~ div .hamburger-icon .line-2 {
    opacity: 0;
  }
  #nav-mobile-toggle:checked ~ div .hamburger-icon .line-3 {
    top: 7px;
    transform: rotate(-45deg);
  }

  @keyframes navPanelIn {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-icon .line {
      transition: none;
    }
    #nav-mobile-toggle:checked ~ .nav-mobile-panel {
      animation: none;
    }
  }

  /* Body scroll lock when mobile panel is open (progressive enhancement) */
  :global(html:has(#nav-mobile-toggle:checked)) {
    overflow: hidden;
  }

  /* ============================================================
     Language toggle — sliding pill + shine sweep + on-load tip
     ============================================================ */
  .lang-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    background: rgba(0, 82, 204, 0.1);
    border: 1px solid rgba(0, 217, 255, 0.25);
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .lang-toggle:hover {
    border-color: #00d9ff;
    box-shadow: 0 0 16px rgba(0, 217, 255, 0.15);
  }

  .lang-toggle::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.12),
      transparent
    );
    animation: shineLoop 3s ease-in-out infinite;
    pointer-events: none;
    z-index: 2;
  }
  @keyframes shineLoop {
    0% {
      left: -80%;
    }
    50% {
      left: 120%;
    }
    100% {
      left: 120%;
    }
  }

  .lang-toggle-pill {
    position: absolute;
    top: 3px;
    left: 3px;
    height: calc(100% - 6px);
    width: calc(50% - 3px);
    background: #0052cc;
    border-radius: 7px;
    box-shadow: 0 0 8px rgba(0, 82, 204, 0.6);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }
  .lang-toggle[data-active="en"] .lang-toggle-pill {
    transform: translateX(calc(100% + 3px));
  }

  .lang-toggle-option {
    padding: 9px 16px;
    font-family: "Manifold CF", Montserrat, system-ui, sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.45);
    position: relative;
    z-index: 1;
    user-select: none;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .lang-toggle-option.is-active {
    color: #ffffff;
  }
  .lang-toggle-flag {
    width: 16px;
    height: 12px;
    border-radius: 2px;
    object-fit: cover;
    display: inline-block;
    vertical-align: middle;
  }
  .lang-toggle-option:not(.is-active):hover {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Tooltip on-load (ES side only, 2s in → fade out at 5s) */
  .lang-toggle-tooltip {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    background: rgba(5, 10, 24, 0.95);
    border: 1px solid rgba(0, 217, 255, 0.35);
    color: #00d9ff;
    font-family: "Manifold CF", Montserrat, system-ui, sans-serif;
    font-weight: 600;
    font-size: 11px;
    padding: 6px 11px;
    border-radius: 7px;
    white-space: nowrap;
    z-index: 10;
    opacity: 0;
    pointer-events: none;
    animation:
      langTipIn 0.4s ease-out 2s forwards,
      langTipOut 0.3s ease-out 5s forwards;
  }
  .lang-toggle-tooltip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: rgba(0, 217, 255, 0.35);
  }
  @keyframes langTipIn {
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }
  @keyframes langTipOut {
    0% {
      opacity: 1;
      visibility: visible;
    }
    99% {
      opacity: 0;
      visibility: visible;
    }
    100% {
      opacity: 0;
      visibility: hidden;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lang-toggle::before {
      animation: none;
    }
    .lang-toggle-tooltip {
      display: none;
    }
  }
</style>

<script>
  // Cierra el panel mobile al navegar a un anchor o link interno
  const toggle = document.getElementById(
    "nav-mobile-toggle"
  ) as HTMLInputElement | null;
  if (toggle) {
    document.querySelectorAll("#nav-mobile-panel a").forEach((a) => {
      a.addEventListener("click", () => {
        toggle.checked = false;
      });
    });
  }
</script>
