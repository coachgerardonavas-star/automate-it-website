---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].ribbon;
---

<section class="ribbon-stat reveal-on-scroll py-10">
  <div class="max-w-2xl mx-auto px-5 lg:px-8 text-center">
    <p
      class="text-base sm:text-lg text-gray-200 leading-relaxed font-semibold"
    >
      {t.message}
    </p>
    <p
      class="text-[10px] text-gray-500 mt-4 uppercase tracking-[0.18em] leading-relaxed"
    >
      {t.source}
    </p>
  </div>
</section>

<style>
  .ribbon-stat {
    background: #080f22;
    border-top: 1px solid rgba(0, 217, 255, 0.1);
    border-bottom: 1px solid rgba(0, 217, 255, 0.1);
  }

  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms ease-out,
      transform 700ms ease-out;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
