---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].ribbon;
---

<section class="ribbon-stat reveal-on-scroll py-10">
  <div class="max-w-2xl mx-auto px-5 lg:px-8 text-center">
    <p class="leading-snug">
      <span
        class="font-heading font-extrabold text-4xl text-[#00D9FF] leading-none align-baseline"
        >{t.bigPart}</span
      ><span class="text-base text-gray-300 leading-relaxed"
        >{t.restPart}</span
      >
    </p>
    <p
      class="text-[10px] text-gray-500 mt-3 uppercase tracking-[0.18em]"
    >
      {t.source}
    </p>
  </div>
</section>

<style>
  .ribbon-stat {
    background: #080f22;
    border-top: 1px solid rgba(0, 217, 255, 0.1);
    border-bottom: 1px solid rgba(0, 217, 255, 0.1);
  }

  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms ease-out,
      transform 700ms ease-out;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
