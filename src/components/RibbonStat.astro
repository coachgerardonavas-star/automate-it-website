---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].ribbon;

const messageParts =
  lang === "es"
    ? {
        before:
          "Cada vez que llama un cliente en inglés y no puedes atender — ",
        highlight: "ese cliente se va con la competencia",
        after: ". Tu agente contesta en inglés aunque tú no estés.",
      }
    : {
        before:
          "Every time an English-speaking customer calls and you can't answer — ",
        highlight: "they go to your competitor",
        after:
          ". Your agent handles it in English, even when you're not available.",
      };
---

<section class="ribbon-stat reveal-on-scroll py-10">
  <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center">
    <p
      class="text-xl sm:text-2xl lg:text-3xl text-white/85 leading-relaxed font-semibold"
    >
      {messageParts.before}<span class="text-white font-bold"
        >{messageParts.highlight}</span
      >{messageParts.after}
    </p>
    <p
      class="text-[10px] text-white/50 mt-4 uppercase tracking-[0.18em] leading-relaxed"
    >
      {t.source}
    </p>
  </div>
</section>

<style>
  .ribbon-stat {
    background: var(--color-blue);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms ease-out,
      transform 700ms ease-out;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
