---
const blocks = [
  {
    prompt: "> agent.tony@receptionist",
    promptCh: 28,
    promptDur: 1.0,
    promptDelay: 0.0,
    lines: [
      { text: "Llamada entrante: María González", delay: 1.1 },
      {
        before: "Calificando lead… ",
        ok: "alto interés",
        after: "",
        delay: 1.6,
      },
      { text: "Agendando cita: jueves 3pm con Dr. Ramos", delay: 2.1 },
      {
        before: "",
        ok: "Confirmación enviada por WhatsApp",
        after: "",
        delay: 2.6,
      },
    ],
  },
  {
    prompt: "> agent.veronica@followup",
    promptCh: 26,
    promptDur: 0.9,
    promptDelay: 3.4,
    lines: [
      { text: "Lead frío detectado: Carlos Méndez · 45 días", delay: 4.4 },
      { text: "Reactivando con secuencia de 3 emails…", delay: 4.9 },
      {
        before: "Respondió: ",
        ok: '"Hablemos esta semana"',
        after: "",
        delay: 5.4,
      },
    ],
  },
  {
    prompt: "> agent.marc@admin",
    promptCh: 18,
    promptDur: 0.7,
    promptDelay: 6.0,
    lines: [
      { text: "Procesando facturas pendientes (12)", delay: 6.8 },
      { text: "Conciliando con extractos bancarios…", delay: 7.3 },
      {
        before: "",
        ok: "12 reconciliadas · 0 discrepancias",
        after: "",
        delay: 7.8,
      },
    ],
  },
];
---

<section
  id="agentes"
  class="py-20 sm:py-28 border-t border-white/5 reveal-on-scroll"
>
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <header class="max-w-3xl mb-12 sm:mb-16">
      <p class="text-[11px] sm:text-xs tracking-[0.28em] uppercase text-brand-cyan mb-4 font-semibold">
        Los agentes en acción
      </p>
      <h2 class="font-heading text-3xl sm:text-5xl leading-tight mb-6">
        Equipos de IA especializados ejecutan tu back-office.
      </h2>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed max-w-2xl">
        Cada agente entrenado para una función específica. Conversan con tus
        sistemas en tiempo real: CRM, calendario, WhatsApp, email. Tú ves los
        resultados; ellos hacen el trabajo.
      </p>
    </header>

    <div class="terminal mx-auto max-w-3xl rounded-lg overflow-hidden border border-white/10 bg-[#0A0F1F] shadow-2xl shadow-brand-cyan/5">
      <div class="terminal-bar flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-white/[0.02]">
        <span class="block w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="block w-3 h-3 rounded-full bg-yellow-500/70"></span>
        <span class="block w-3 h-3 rounded-full bg-green-500/70"></span>
        <span class="ml-3 text-[11px] tracking-widest uppercase text-white/40 font-mono">
          automate-it · live
        </span>
      </div>

      <div class="terminal-body px-5 sm:px-6 py-6 sm:py-7 font-mono text-[13px] sm:text-sm leading-[1.9] text-white/85">
        {
          blocks.map((block, bi) => (
            <div class={bi > 0 ? "mt-5" : ""}>
              <div
                class="line line-type text-brand-cyan"
                style={`--ch: ${block.promptCh}; --dur: ${block.promptDur}s; --delay: ${block.promptDelay}s;`}
              >
                {block.prompt}
              </div>
              {block.lines.map((line) =>
                line.text ? (
                  <div
                    class="line line-fade pl-3 text-white/80"
                    style={`--delay: ${line.delay}s;`}
                  >
                    {line.text}
                  </div>
                ) : (
                  <div
                    class="line line-fade pl-3"
                    style={`--delay: ${line.delay}s;`}
                  >
                    <span class="text-white/80">{line.before}</span>
                    <span class="text-brand-lime">✓ {line.ok}</span>
                    <span class="text-white/80">{line.after}</span>
                  </div>
                )
              )}
            </div>
          ))
        }
        <span class="cursor" aria-hidden="true"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms ease-out,
      transform 700ms ease-out;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .terminal .line {
    display: block;
  }
  .terminal .line-type {
    width: 0;
    white-space: nowrap;
    overflow: hidden;
  }
  .terminal .line-fade {
    opacity: 0;
    transform: translateY(4px);
  }

  .terminal.is-visible .line-type {
    animation:
      typing var(--dur, 1s) steps(var(--ch, 30)) var(--delay, 0s) forwards;
  }
  .terminal.is-visible .line-fade {
    animation: lineFade 0.5s var(--delay, 0s) forwards;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 1em;
    background: #00d9ff;
    margin-left: 4px;
    vertical-align: text-bottom;
    animation: blink 0.85s steps(1) infinite;
  }

  @keyframes typing {
    to {
      width: calc(var(--ch) * 1ch);
    }
  }
  @keyframes lineFade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .terminal .line-type {
      width: auto !important;
      animation: none !important;
    }
    .terminal .line-fade {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .cursor {
      animation: none;
    }
  }
</style>

<script>
  const terminalObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          terminalObserver.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.35 }
  );

  document
    .querySelectorAll(".terminal")
    .forEach((el) => terminalObserver.observe(el));
</script>
