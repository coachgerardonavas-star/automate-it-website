---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].ctaFinal;
---

<section
  id="diagnostico"
  class="py-20 sm:py-28 bg-[var(--color-blue)] border-t border-white/10 reveal-on-scroll relative overflow-hidden"
>
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[24rem] w-[60rem] rounded-full bg-white/[0.06] blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-5 lg:px-8 text-center">
    <p class="text-sm sm:text-xs tracking-[0.28em] uppercase text-white mb-4 font-semibold">
      {t.eyebrow}
    </p>
    <h2 class="font-heading text-3xl sm:text-5xl leading-tight mb-6">
      {t.titleLine1}<br class="sm:hidden" />
      <span class="sm:inline"> {t.titleLine2}</span><br />
      <span class="text-white/60">{t.titleLine3}</span>
    </h2>
    <p class="text-base sm:text-lg text-white/80 leading-relaxed mb-12 max-w-2xl mx-auto">
      {t.subtitle}
    </p>

    <form
      id="cta-form"
      class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mb-4 text-left"
      novalidate
      data-error-msg={t.errorAllFields}
      data-error-fallback={t.errorSubmitFallback}
      data-submitting={t.submitting}
      data-submit-label={t.submitButton}
    >
      <label class="block">
        <span class="sr-only">{t.formNamePlaceholder}</span>
        <input
          type="text"
          name="name"
          placeholder={t.formNamePlaceholder}
          required
          autocomplete="name"
          class="w-full px-4 py-3 rounded bg-white/[0.08] border border-white/25 placeholder-white/50 text-white focus:outline-none focus:border-white transition-colors"
        />
      </label>
      <label class="block">
        <span class="sr-only">{t.formEmailPlaceholder}</span>
        <input
          type="email"
          name="email"
          placeholder={t.formEmailPlaceholder}
          required
          autocomplete="email"
          class="w-full px-4 py-3 rounded bg-white/[0.08] border border-white/25 placeholder-white/50 text-white focus:outline-none focus:border-white transition-colors"
        />
      </label>
      <label class="block">
        <span class="sr-only">{t.formBizTypePlaceholder}</span>
        <select
          name="business_type"
          required
          class="w-full px-4 py-3 rounded bg-white/[0.08] border border-white/25 text-white focus:outline-none focus:border-white transition-colors appearance-none cursor-pointer"
        >
          <option value="" class="bg-[var(--color-bg-dark)] text-white">{t.formBizTypePlaceholder}</option>
          {
            t.businessTypes.map((bt) => (
              <option value={bt} class="bg-[var(--color-bg-dark)] text-white">
                {bt}
              </option>
            ))
          }
        </select>
      </label>
      <button
        type="submit"
        class="btn-cta sm:col-span-3 inline-flex items-center justify-center px-6 py-3 rounded font-semibold bg-white text-[var(--color-blue)] hover:bg-white/90 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
      >
        {t.submitButton}
      </button>
    </form>

    <p id="cta-error" class="hidden text-sm text-red-200 mb-2"></p>

    <div
      id="cta-success"
      class="hidden p-6 rounded-lg border border-brand-lime/50 bg-white/10 text-left"
      role="status"
      aria-live="polite"
    >
      <p class="font-heading text-xl mb-2 text-brand-lime">{t.successHeading}</p>
      <p class="text-sm sm:text-base text-white/90">
        {t.successBody}
      </p>
    </div>

    <p class="mt-6 text-sm text-white/60">
      {t.privacyDisclaimer}
    </p>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms ease-out,
      transform 700ms ease-out;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  import { submitToHubSpot } from "../lib/hubspot";
  import { HUBSPOT_FORM_GUID_CTA } from "../config/site";

  const form = document.getElementById("cta-form") as HTMLFormElement | null;
  const error = document.getElementById("cta-error");
  const success = document.getElementById("cta-success");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !error || !success) return;

    error.classList.add("hidden");
    error.textContent = "";

    if (!form.checkValidity()) {
      error.textContent = form.dataset.errorMsg ?? "";
      error.classList.remove("hidden");
      form.reportValidity();
      return;
    }

    const submitBtn = form.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement | null;
    const restoreBtn = () => {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = form.dataset.submitLabel ?? "";
      }
    };
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = form.dataset.submitting ?? "";
    }

    const data = Object.fromEntries(new FormData(form)) as Record<
      string,
      string
    >;

    try {
      await submitToHubSpot(HUBSPOT_FORM_GUID_CTA, [
        { name: "firstname", value: data.name ?? "" },
        { name: "email", value: data.email ?? "" },
        { name: "industry", value: data.business_type ?? "" },
      ]);
      form.classList.add("hidden");
      success.classList.remove("hidden");
    } catch (err) {
      console.error("[lead] CTA final HubSpot error:", err);
      error.textContent = form.dataset.errorFallback ?? "";
      error.classList.remove("hidden");
      restoreBtn();
    }
  });
</script>
