---
import { translations, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].resultados;
---

<section
  id="resultados"
  class="py-20 sm:py-28 border-t border-white/5 reveal-on-scroll"
>
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <header class="max-w-3xl mb-12 sm:mb-16">
      <p class="text-sm sm:text-xs tracking-[0.28em] uppercase text-brand-cyan mb-4 font-semibold">
        {t.eyebrow}
      </p>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed">
        {t.subtitle}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6 max-w-5xl">
      {
        t.cards.map((card) => (
          <article class="flex flex-col p-7 sm:p-8 rounded-md bg-white/[0.025] border border-white/5 hover:border-brand-cyan/40 transition-colors duration-200 ease-brand">
            <span
              class="text-3xl sm:text-4xl mb-4 leading-none select-none"
              aria-hidden="true"
            >
              {card.icon}
            </span>
            <blockquote class="text-base sm:text-lg text-white/90 leading-relaxed font-heading font-normal">
              <span aria-hidden="true">“</span>{card.quote}<span aria-hidden="true">”</span>
            </blockquote>
          </article>
        ))
      }
    </div>

    <p class="mt-8 text-sm text-white/55 italic">
      {t.disclaimer}
    </p>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms ease-out,
      transform 700ms ease-out;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
