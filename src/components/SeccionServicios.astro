---
import { translations, type Lang } from "../i18n/translations";
import { jsonLd } from "../lib/jsonld";
import { STRIPE_PRICES } from "../lib/stripe";
import { STRIPE_CHECKOUT_WORKER_URL } from "../config/site";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang].servicios;
const diagPath = "/diagnostico";

const planPriceBySku: Record<string, { monthly: string; setup: string }> = {
  STARTER: {
    monthly: STRIPE_PRICES.STARTER_BASE.monthly,
    setup: STRIPE_PRICES.STARTER_BASE.setup,
  },
  PROFESSIONAL: {
    monthly: STRIPE_PRICES.PROFESSIONAL_BASE.monthly,
    setup: STRIPE_PRICES.PROFESSIONAL_BASE.setup,
  },
};

const serviceNames =
  lang === "es"
    ? [
        "Plan Starter — Recepcionista IA",
        "Plan Professional HIPAA — Recepcionista IA",
      ]
    : [
        "Starter Plan — AI Receptionist",
        "Professional HIPAA Plan — AI Receptionist",
      ];

const orgRef = {
  "@type": "Organization",
  name: "Automate IT",
  url: "https://yourbizupgraded.com",
};

const serviceSchemas = t.plans.map((plan, i) => {
  const priceNumber = plan.price.replace(/[^0-9.]/g, "");
  return {
    "@context": "https://schema.org",
    "@type": "Service",
    name: serviceNames[i],
    description: plan.description,
    provider: orgRef,
    areaServed: "United States",
    offers: {
      "@type": "Offer",
      price: priceNumber,
      priceCurrency: "USD",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: priceNumber,
        priceCurrency: "USD",
        billingIncrement: 1,
        unitCode: "MON",
      },
    },
  };
});
---

{
  serviceSchemas.map((schema) => (
    <script
      type="application/ld+json"
      is:inline
      set:html={jsonLd(schema)}
    />
  ))
}

<section
  id="servicios"
  class="py-20 sm:py-28 border-t border-white/5 reveal-on-scroll"
>
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <header class="max-w-3xl mb-12 sm:mb-16">
      <p class="text-sm sm:text-xs tracking-[0.28em] uppercase text-brand-cyan mb-4 font-semibold">
        {t.eyebrow}
      </p>
      <h2 class="font-heading text-3xl sm:text-5xl leading-tight mb-6">
        {t.titleLine1}<br />
        <span class="text-white/45">{t.titleLine2}</span>
      </h2>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed max-w-2xl">
        {t.subtitle}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6 mb-16 sm:mb-20">
      {
        t.plans.map((plan) => (
          <article
            id={`plan-${plan.sku.toLowerCase()}`}
            class:list={[
              "relative flex flex-col p-7 sm:p-8 rounded-md bg-white/[0.025] border transition-all duration-200 ease-brand scroll-mt-20",
              plan.badge
                ? "border-brand-lime/40 hover:border-brand-lime"
                : "border-white/5 hover:border-brand-cyan/40",
            ]}
          >
            {plan.badge && (
              <span class="absolute -top-3 left-7 sm:left-8 inline-flex items-center px-3 py-1 rounded-full text-[10px] font-semibold tracking-widest uppercase bg-brand-lime text-brand-bg">
                {plan.badge}
              </span>
            )}
            <p class="font-mono text-xs sm:text-[10px] tracking-widest uppercase text-white/45 mb-3">
              {plan.sku}
            </p>
            <h3 class="font-heading text-2xl sm:text-3xl mb-2 leading-snug">
              {plan.name}
            </h3>
            <div class="mb-2 flex items-baseline gap-2">
              <span class="font-heading text-3xl sm:text-4xl text-white">
                {plan.price}
              </span>
              <span class="text-sm sm:text-sm text-white/70">
                {plan.priceUnit}
              </span>
            </div>
            <p class="text-sm sm:text-xs text-white/70 mb-4 font-mono">{plan.setup}</p>
            <p class="text-base sm:text-base text-white/80 leading-relaxed mb-6">
              {plan.description}
            </p>
            <ul class="space-y-2.5 flex-1">
              {plan.features.map((feature) => (
                <li class="flex gap-3 text-sm sm:text-sm text-white/85 leading-snug">
                  <span class="text-brand-cyan mt-0.5 shrink-0">→</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            {planPriceBySku[plan.sku] && (
              <div class="mt-6">
                <button
                  type="button"
                  data-stripe-checkout
                  data-price-monthly={planPriceBySku[plan.sku].monthly}
                  data-price-setup={planPriceBySku[plan.sku].setup}
                  data-plan-name={plan.name}
                  data-lang={lang}
                  data-label-default={t.checkoutLabel}
                  data-label-loading={t.checkoutLoading}
                  class="btn-cta block w-full text-center px-5 py-3 rounded-sm text-sm font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 transition-colors duration-200 ease-brand disabled:opacity-60 disabled:cursor-not-allowed"
                >
                  {t.checkoutLabel}
                </button>
                <p
                  data-stripe-error
                  class="hidden mt-2 text-sm text-[#E5484D]"
                  role="alert"
                >
                  {t.checkoutError}
                </p>
              </div>
            )}
            <a
              href={diagPath}
              class="mt-4 inline-block text-sm text-white/70 hover:text-brand-cyan transition-colors"
            >
              {t.planDiagnosticHint}
            </a>
          </article>
        ))
      }
    </div>

    <div class="mb-16 sm:mb-20">
      <header class="mb-8 sm:mb-10">
        <p class="text-sm sm:text-xs tracking-[0.28em] uppercase text-brand-cyan mb-3 font-semibold">
          {t.modulesEyebrow}
        </p>
        <p class="text-base sm:text-base text-white/75 max-w-2xl leading-relaxed">
          {t.modulesSubtitle}
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-6">
        {
          t.modules.map((mod) => (
            <article class="flex flex-col p-6 rounded-md bg-white/[0.025] border border-white/5 hover:border-brand-cyan/40 transition-all duration-200 ease-brand">
              <div class="flex items-center justify-between mb-3">
                <p class="font-mono text-xs sm:text-[10px] tracking-widest uppercase text-white/45">
                  {mod.sku}
                </p>
                {mod.hipaa ? (
                  <span class="font-mono text-[10px] sm:text-[9px] tracking-wider uppercase text-brand-lime">
                    HIPAA ✓
                  </span>
                ) : (
                  <span class="font-mono text-[10px] sm:text-[9px] tracking-wider uppercase text-white/40">
                    no HIPAA
                  </span>
                )}
              </div>
              <h3 class="font-heading text-lg sm:text-xl mb-3 leading-snug">
                {mod.name}
              </h3>
              <p class="text-sm sm:text-sm text-white/75 leading-relaxed mb-5 flex-1">
                {mod.description}
              </p>
              <div class="space-y-2 pt-4 border-t border-white/5 text-sm sm:text-xs">
                <div class="flex justify-between gap-2">
                  <span class="text-white/55">Starter</span>
                  <span class="text-white/90 font-mono text-right">
                    {mod.priceStarter}
                  </span>
                </div>
                <div class="flex justify-between gap-2">
                  <span class="text-white/55">Professional</span>
                  <span class="text-white/90 font-mono text-right">
                    {mod.pricePro}
                  </span>
                </div>
                <div class="flex justify-between gap-2 text-sm sm:text-xs text-white/55">
                  <span>{mod.setupStarter}</span>
                  <span>{mod.setupPro}</span>
                </div>
              </div>
              {"hipaaNote" in mod && mod.hipaaNote && (
                <p class="mt-3 text-sm sm:text-xs text-white/55 italic leading-snug">
                  {mod.hipaaNote}
                </p>
              )}
              <a
                href={diagPath}
                class="mt-4 inline-block text-sm sm:text-xs text-white/65 hover:text-brand-cyan transition-colors"
              >
                {t.moduleDiagnosticHint}
              </a>
            </article>
          ))
        }
      </div>
    </div>

    <div class="mb-12 sm:mb-14">
      <p class="text-sm sm:text-xs tracking-[0.28em] uppercase text-brand-cyan mb-6 font-semibold">
        {t.examplesEyebrow}
      </p>
      <div class="rounded-md border border-white/5 bg-white/[0.02] divide-y divide-white/5">
        {
          t.examples.map((ex) => (
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-4 px-5 sm:px-6 py-4">
              <div class="min-w-0 flex-1">
                <p class="text-sm sm:text-base text-white/90 font-semibold">
                  {ex.label}
                </p>
                <p class="text-sm sm:text-xs text-white/55 mt-0.5 font-mono">
                  {ex.detail}
                </p>
              </div>
              <p class="font-heading text-xl sm:text-2xl text-brand-cyan font-mono shrink-0">
                {ex.total}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="text-center">
      <a
        href={diagPath}
        class="btn-cta inline-flex items-center justify-center px-6 py-3 rounded-sm font-semibold bg-brand-cyan text-brand-bg hover:bg-brand-cyan/90 transition-colors duration-200 ease-brand"
      >
        {t.cta}
      </a>
      <p class="mt-4 text-sm sm:text-sm text-white/65 max-w-md mx-auto">
        {t.ctaHint}
      </p>
    </div>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms ease-out,
      transform 700ms ease-out;
  }
  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline define:vars={{ workerUrl: STRIPE_CHECKOUT_WORKER_URL }}>
  (function () {
    var buttons = document.querySelectorAll("[data-stripe-checkout]");
    if (!buttons.length || !workerUrl) return;

    buttons.forEach(function (btn) {
      btn.addEventListener("click", async function () {
        var defaultLabel = btn.getAttribute("data-label-default") || "";
        var loadingLabel = btn.getAttribute("data-label-loading") || "";
        var errorEl = btn.parentElement
          ? btn.parentElement.querySelector("[data-stripe-error]")
          : null;

        btn.disabled = true;
        btn.textContent = loadingLabel;
        if (errorEl) errorEl.classList.add("hidden");

        try {
          var res = await fetch(workerUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              priceIdMonthly: btn.getAttribute("data-price-monthly"),
              priceIdSetup: btn.getAttribute("data-price-setup"),
              planName: btn.getAttribute("data-plan-name"),
              lang: btn.getAttribute("data-lang"),
            }),
          });
          var data = await res.json().catch(function () {
            return null;
          });
          if (res.ok && data && typeof data.url === "string") {
            window.location.href = data.url;
            return;
          }
          throw new Error("checkout-failed");
        } catch (err) {
          btn.disabled = false;
          btn.textContent = defaultLabel;
          if (errorEl) errorEl.classList.remove("hidden");
        }
      });
    });
  })();
</script>
