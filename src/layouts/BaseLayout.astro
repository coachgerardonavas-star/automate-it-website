---
import "../styles/global.css";
import openSans400Url from "@fontsource/open-sans/files/open-sans-latin-400-normal.woff2?url";
import openSans600Url from "@fontsource/open-sans/files/open-sans-latin-600-normal.woff2?url";
import { translations, type Lang } from "../i18n/translations";
import { jsonLd } from "../lib/jsonld";
import ChatbotWidget from "../components/ChatbotWidget.astro";
import {
  GA_ID,
  SEARCH_CONSOLE_VERIFICATION,
  isGAEnabled,
  isSearchConsoleEnabled,
} from "../config/site";

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  noindex?: boolean;
  chatbot?: boolean;
}

const {
  lang = "es",
  title,
  description,
  noindex = false,
  chatbot = true,
} = Astro.props;
const t = translations[lang];
const pageTitle = title ?? t.siteTitle;
const pageDescription = description ?? t.siteDescription;
const ogLocale = lang === "en" ? "en_US" : "es_MX";
const htmlLang = lang === "en" ? "en" : "es";
const enableGA = isGAEnabled();
const enableSC = isSearchConsoleEnabled();
const canonicalUrl = Astro.url.href;
const ogImageUrl = "https://yourbizupgraded.com/assets/logo-hero.png";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Automate IT",
  alternateName: "Automate IT LLC",
  url: "https://yourbizupgraded.com",
  logo: ogImageUrl,
  description:
    "Recepcionista IA 24/7 para pequeños negocios. Agentes de voz, chatbots WhatsApp y CRM automatizado. HIPAA-compliant para sector salud.",
  email: "automateit@yourbizupgraded.com",
  areaServed: ["Florida", "United States"],
  serviceType: [
    "AI Voice Agent",
    "WhatsApp Chatbot",
    "CRM Automation",
    "HIPAA Compliant AI Receptionist",
  ],
  sameAs: [],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Automate IT",
  url: "https://yourbizupgraded.com",
  potentialAction: {
    "@type": "SearchAction",
    target: "https://yourbizupgraded.com/?s={search_term_string}",
    "query-input": "required name=search_term_string",
  },
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {
      enableSC && (
        <meta
          name="google-site-verification"
          content={SEARCH_CONSOLE_VERIFICATION}
        />
      )
    }
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Automate IT" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/manifold-cf-extrabold.woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={openSans400Url}
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={openSans600Url}
      crossorigin="anonymous"
    />

    <link
      rel="alternate"
      hreflang="es"
      href={new URL("/", Astro.site).toString()}
    />
    <link
      rel="alternate"
      hreflang="en"
      href={new URL("/en/", Astro.site).toString()}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL("/", Astro.site).toString()}
    />

    {
      enableGA && (
        <script is:inline define:vars={{ GA_ID }}>
          // Defer GA4 ~2s after window.load to keep gtag.js (~160KB) out of
          // the LCP / TBT critical path while still firing in time to track
          // the visit. NOTE: script body must be plain JS — wrapping it in a
          // {`...`} JSX template literal renders the GA loader as a string
          // inside a block statement and it never executes.
          (function(){
            function loadGA(){
              var s = document.createElement('script');
              s.async = true;
              s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
              document.head.appendChild(s);
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              window.gtag = gtag;
              gtag('js', new Date());
              gtag('config', GA_ID, { anonymize_ip: true });
            }
            if (document.readyState === 'complete') {
              setTimeout(loadGA, 2000);
            } else {
              window.addEventListener('load', function(){ setTimeout(loadGA, 2000); });
            }
          })();
        </script>
      )
    }

    <script
      type="application/ld+json"
      is:inline
      set:html={jsonLd(organizationSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={jsonLd(websiteSchema)}
    />

    <title>{pageTitle}</title>
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text-primary)]">
    <slot />
    {chatbot && <ChatbotWidget lang={lang} />}
  </body>
</html>
