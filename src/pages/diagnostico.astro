---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import DiagnosticoForm from "../components/DiagnosticoForm.astro";
import { translations } from "../i18n/translations";

const lang = "es" as const;
const t = translations[lang].diagnosticoPage;
---

<BaseLayout lang={lang} title={t.title}>
  <Nav lang={lang} />
  <main class="min-h-[60vh] pt-10 pb-24">
    <div class="max-w-2xl mx-auto px-5 lg:px-8">
      <a
        href="/"
        class="inline-block text-sm text-white/60 hover:text-brand-cyan transition-colors mb-8"
      >
        {t.backLink}
      </a>

      <header class="mb-10">
        <h1 class="font-heading text-3xl sm:text-5xl leading-tight mb-4">
          {t.heading}
        </h1>
        <p class="text-base sm:text-lg text-white/75 leading-relaxed">
          {t.subheading}
        </p>
      </header>

      <DiagnosticoForm lang={lang} />
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>
